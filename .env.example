# ==============================================================================
# CaseFlow Operations — Environment Variables
# Copy this file to .env.local and fill in every value before running the app.
# Lines marked [REQUIRED] will cause runtime errors or broken features if unset.
# Lines marked [OPTIONAL] have working defaults but should be overridden in prod.
# ==============================================================================


# ── App URL ──────────────────────────────────────────────────────────────────
# The canonical public URL of this deployment (used in emails, OAuth callbacks).
# Must include protocol. No trailing slash.
# [REQUIRED for production]
APP_BASE_URL=https://yourcustomdomain.com

# Required by NextAuth for redirect URLs (must match your Vercel custom domain)
# [REQUIRED]
NEXTAUTH_URL=https://yourcustomdomain.com


# ── Organization Identity ─────────────────────────────────────────────────────
# These are the ONLY values that need to change when white-labeling for a new org.
# All NEXT_PUBLIC_ vars are exposed to the browser.

# [REQUIRED]
NEXT_PUBLIC_ORG_NAME=T.O.O.LS INC
NEXT_PUBLIC_ORG_SHORT=SDTOOLSINC
NEXT_PUBLIC_ORG_SLUG=sdtoolsinc
WORKSPACE_DOMAIN=yourcustomdomain.com

# [OPTIONAL]
NEXT_PUBLIC_ORG_TAGLINE=Empowering communities through compassionate service.
NEXT_PUBLIC_ORG_MISSION=Our mission is to transform lives through comprehensive, client-centered care.
NEXT_PUBLIC_PRODUCT_NAME=CaseFlow Operations
NEXT_PUBLIC_STAFF_MOTTO=The Champ Is Here
PROGRAM_TYPE=case-management


# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get keys at https://resend.com — your Resend sender domain must be verified.
# EMAIL_FROM must use your verified domain; Resend will reject unverified senders.

# [REQUIRED]
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourcustomdomain.com
SUPPORT_EMAIL=support@yourcustomdomain.com

# Used for secondary admin notifications on access request denials.
# [OPTIONAL — defaults to RESEND_API_KEY]
RESEND_API_KEY_2=re_xxxxxxxxxxxxxxxxxxxx

# Admin email(s) that receive new client access request notifications.
# [OPTIONAL — defaults to SUPPORT_EMAIL]
ADMIN_NOTIFY_EMAIL=admin@yourcustomdomain.com
ADMIN_NOTIFY_EMAIL_2=

# Where case-note and document upload notifications are forwarded server-side.
# [OPTIONAL — defaults to SUPPORT_EMAIL]
NOTIFY_FORWARDING_EMAIL=notifications@yourcustomdomain.com

# Client-visible notification address shown in staff settings UI.
# [OPTIONAL]
NEXT_PUBLIC_NOTIFY_EMAIL=notifications@yourcustomdomain.com


# ── Authentication ────────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: npx auth secret
# DATA_ENCRYPTION_KEY is used to encrypt PHI at rest in KV. Generate a random
# 32-byte hex string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# [REQUIRED]
AUTH_SECRET=generate-with-npx-auth-secret

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourcustomdomain.com/api/auth/callback/google
# [REQUIRED for staff/admin login]
AUTH_GOOGLE_ID=xxxxxxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# [REQUIRED for production — must be different from AUTH_SECRET]
DATA_ENCRYPTION_KEY=64-char-hex-string-here

# TOTP secret for 2FA. Generate with: node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
# [OPTIONAL]
TWO_FA_SECRET=your-totp-secret-hex


# ── Access Control ────────────────────────────────────────────────────────────
# Comma-separated lists of email addresses/domains allowed to log in.
# Staff domain examples: "@yourcustomdomain.com,specificstaff@partner.org"
# Leave blank to allow any authenticated Google user for that role.

# [REQUIRED — at minimum set ADMIN_ALLOWLIST to lock down admin access]
# Accepts full emails (user@domain.com) or domain wildcards (@domain.com)
ADMIN_ALLOWLIST=admin@yourcustomdomain.com
STAFF_ALLOWLIST=@yourcustomdomain.com
CLIENT_ALLOWLIST=


# ── Convex (Realtime Database) ────────────────────────────────────────────────
# Create a project at https://dashboard.convex.dev
# After cloning, run: npx convex dev (generates convex/_generated/)
# Then set your production URL here.

# [REQUIRED]
NEXT_PUBLIC_CONVEX_URL=https://your-project-id.convex.cloud


# ── Vercel KV (Encrypted Data Store) ─────────────────────────────────────────
# Create a KV database in your Vercel project dashboard.
# Used for encrypted PHI records, password reset tokens, and session data.
# Without KV, the app falls back to in-memory (dev only — data lost on restart).

# [REQUIRED for production]
KV_REST_API_URL=https://your-kv.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token

# Vercel Blob — for file uploads (documents, profile photos)
# [REQUIRED for production]
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx


# ── Compliance Flags ──────────────────────────────────────────────────────────
# Set these to "true" after completing the relevant compliance steps.
# The compliance dashboard reads these to show your org posture.

# [OPTIONAL — set to "true" when your PHI handling workflow is documented & approved]
PHI_WORKFLOW_APPROVED=false

# [OPTIONAL — set to "true" when a BAA is signed with all data processors]
BAA_CONFIRMED=false


# ── External Integrations ─────────────────────────────────────────────────────
# All optional. Each defaults to the generic public URL if not set.

# Google Chat webhook for staff Champions channel
# Note: the env var name is Champions_Web_Hook (exact casing)
Champions_Web_Hook=https://chat.googleapis.com/v1/spaces/xxx/messages?key=yyy

# HMIS system login URL (shown as a quick-link in dashboards)
HMIS_SYSTEM_URL=https://your-org.hmis-system.com/login

# Google Sites internal resource hub
GOOGLE_SITE_URL=https://sites.google.com/your-org-site

# Microsoft integrations (shown as quick links to staff/clients)
NEXT_PUBLIC_OUTLOOK_URL=https://outlook.office.com
NEXT_PUBLIC_TEAMS_URL=https://teams.microsoft.com
NEXT_PUBLIC_SHAREPOINT_URL=https://yourorg.sharepoint.com

# Zoom (shown as quick link for virtual meetings)
NEXT_PUBLIC_ZOOM_URL=https://zoom.us/j/your-meeting-id


# ── Enterprise / Compliance ───────────────────────────────────────────────────
# Bearer token required to call /api/enterprise/* and seed endpoints.
# Generate: openssl rand -base64 24
# [REQUIRED if using enterprise control plane or seed endpoints]
SETUP_TOKEN=change-me-to-a-random-secret
